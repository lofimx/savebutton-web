<% content_for :app_layout, true %>
<% content_for :hide_add_button, true %>

<div class="py-4" data-controller="avatar-cropper">
  <div class="text-center mb-4">
    <button type="button" class="avatar-upload-button" data-action="avatar-cropper#openFilePicker" title="Change avatar">
      <% if @user.avatar.attached? %>
        <%= image_tag @user.avatar, class: "profile-avatar profile-avatar-large profile-avatar-image" %>
      <% else %>
        <div class="profile-avatar profile-avatar-large">
          <%= @user.email_address[0].upcase %>
        </div>
      <% end %>
      <div class="avatar-upload-overlay">
        <i class="bi bi-camera fs-4"></i>
      </div>
    </button>
    <input type="file" accept="image/*" class="visually-hidden" data-avatar-cropper-target="input" data-action="change->avatar-cropper#fileSelected">
    <h1 class="h3 mt-3">Account</h1>
    <p class="text-body-secondary"><%= Current.user.email_address %></p>
  </div>

  <%# Avatar Cropper Modal %>
  <div class="modal fade" id="avatarCropperModal" tabindex="-1" aria-labelledby="avatarCropperLabel" aria-hidden="true" data-avatar-cropper-target="modal">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="avatarCropperLabel">Crop Avatar</h5>
          <button type="button" class="btn-close" data-action="avatar-cropper#cancel" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="avatar-cropper-container mb-3">
            <img data-avatar-cropper-target="image" class="avatar-cropper-image">
          </div>
          <div class="text-center">
            <p class="text-body-secondary small">Preview</p>
            <img data-avatar-cropper-target="preview" class="avatar-preview-image">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-action="avatar-cropper#cancel">Cancel</button>
          <button type="button" class="btn btn-primary" data-action="avatar-cropper#save">Save Avatar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title">Email Address</h5>
          <%= form_with url: account_path, method: :patch do |f| %>
            <div class="mb-3">
              <label for="email_address" class="form-label">Email</label>
              <%= f.email_field :email_address, value: @user.email_address, class: "form-control", required: true %>
            </div>
            <%= f.submit "Update Email", class: "btn btn-primary" %>
          <% end %>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title"><%= @user.incidental_password? ? "Set Password" : "Change Password" %></h5>
          <%= form_with url: account_path, method: :patch do |f| %>
            <div class="mb-3">
              <label for="current_password" class="form-label">Current Password</label>
              <% if @user.incidental_password? %>
                <%= f.password_field :current_password, class: "form-control", disabled: true, placeholder: "Not required" %>
                <div class="form-text">Your account was created by <%= provider_name(@user.identities.first&.provider) %></div>
              <% else %>
                <%= f.password_field :current_password, class: "form-control", autocomplete: "current-password" %>
              <% end %>
            </div>
            <div class="mb-3">
              <label for="password" class="form-label">New Password</label>
              <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
              <div class="form-text">Minimum 8 characters</div>
            </div>
            <div class="mb-3">
              <label for="password_confirmation" class="form-label">Confirm New Password</label>
              <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
            </div>
            <%= f.submit(@user.incidental_password? ? "Set Password" : "Update Password", class: "btn btn-primary") %>
          <% end %>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title">Connected Accounts</h5>
          <p class="text-body-secondary small">Manage your connected login methods.</p>

          <% if @user.identities.any? %>
            <% @user.identities.each do |identity| %>
              <div class="connected-account">
                <div class="connected-account-info">
                  <span class="provider-icon"><%= provider_icon(identity.provider) %></span>
                  <span><%= provider_name(identity.provider) %></span>
                </div>
                <% if @user.identities.count > 1 || @user.password_digest.present? %>
                  <%= button_to "Disconnect", identity_account_path(identity_id: identity.id), method: :delete, class: "btn btn-sm btn-outline-secondary", data: { turbo_confirm: "Are you sure you want to disconnect #{provider_name(identity.provider)}?" } %>
                <% else %>
                  <span class="text-body-secondary small">Set a password to disconnect</span>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="text-body-secondary">No connected accounts.</p>
          <% end %>

          <div class="mt-3">
            <p class="text-body-secondary small">Connect additional accounts:</p>
            <div class="d-flex flex-wrap gap-2">
              <% unless @user.identities.exists?(provider: "google_oauth2") %>
                <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" do %>
                  <%= render "shared/google_icon" %>
                  <span>Google</span>
                <% end %>
              <% end %>
              <% unless @user.identities.exists?(provider: "microsoft_graph") %>
                <%= button_to "/auth/microsoft_graph", method: :post, data: { turbo: false }, class: "btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" do %>
                  <%= render "shared/microsoft_icon" %>
                  <span>Microsoft</span>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title">Log Out</h5>
          <p class="text-body-secondary small">End your session in this browser.</p>
          <%= button_to "Log Out", session_path, method: :delete, class: "btn btn-outline-danger" %>
        </div>
      </div>
    </div>
  </div>
</div>
