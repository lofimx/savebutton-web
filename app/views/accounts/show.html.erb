<% content_for :app_layout, true %>
<% content_for :hide_add_button, true %>

<div class="min-h-screen pt-[calc(60px+1.5rem)] px-6 pb-6 bg-neutral-50 dark:bg-neutral-950" data-controller="avatar-cropper">
  <div class="max-w-xl mx-auto">
    <div class="text-center mb-6">
      <button type="button" class="relative bg-transparent border-none p-0 cursor-pointer rounded-full overflow-hidden w-20 h-20 focus-visible:ring-2 focus-visible:ring-primary-400" data-action="avatar-cropper#openFilePicker" title="Change avatar">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "w-20 h-20 rounded-full object-cover" %>
        <% else %>
          <div class="w-20 h-20 rounded-full bg-primary-400 text-neutral-900 flex items-center justify-center text-3xl font-semibold">
            <%= @user.email_address[0].upcase %>
          </div>
        <% end %>
        <div class="absolute inset-0 bg-black/50 flex items-center justify-center opacity-0 hover:opacity-100 focus-visible:opacity-100 transition-opacity rounded-full text-white">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
            <path d="M12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm0 8a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm6.5-12H18l-1.5-2h-9L6 5H5.5A2.5 2.5 0 0 0 3 7.5v9A2.5 2.5 0 0 0 5.5 19h13a2.5 2.5 0 0 0 2.5-2.5v-9A2.5 2.5 0 0 0 18.5 5z"/>
          </svg>
        </div>
      </button>
      <input type="file" accept="image/*" class="visually-hidden" data-avatar-cropper-target="input" data-action="change->avatar-cropper#fileSelected">
      <h1 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mt-3">Account</h1>
      <p class="text-sm text-neutral-500"><%= Current.user.email_address %></p>
    </div>

    <!-- Avatar Cropper Modal -->
    <div class="modal-backdrop" data-avatar-cropper-target="modal">
      <div class="bg-white dark:bg-neutral-800 rounded-2xl border border-neutral-200 dark:border-neutral-700 shadow-lg max-w-xl w-full max-h-[90vh] overflow-hidden flex flex-col">
        <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-200 dark:border-neutral-700">
          <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">Crop Avatar</h2>
          <button type="button" class="text-3xl text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 bg-transparent border-none cursor-pointer leading-none p-0" data-action="avatar-cropper#cancel">&times;</button>
        </div>
        <div class="p-6 flex gap-6 overflow-hidden flex-1 max-sm:flex-col">
          <div class="flex-1 min-w-0 max-h-[400px] bg-neutral-100 dark:bg-neutral-900 rounded-lg overflow-hidden">
            <img data-avatar-cropper-target="image" class="block max-w-full">
          </div>
          <div class="flex flex-col items-center gap-3 max-sm:flex-row max-sm:justify-center">
            <p class="text-xs text-neutral-500">Preview</p>
            <img data-avatar-cropper-target="preview" class="w-[120px] h-[120px] rounded-full object-cover border-2 border-neutral-200 dark:border-neutral-700 max-sm:w-20 max-sm:h-20">
          </div>
        </div>
        <div class="flex justify-end gap-3 px-6 py-4 border-t border-neutral-200 dark:border-neutral-700">
          <button type="button" class="px-4 py-2 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors cursor-pointer" data-action="avatar-cropper#cancel">Cancel</button>
          <button type="button" class="px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors cursor-pointer border-none" data-action="avatar-cropper#save">Save Avatar</button>
        </div>
      </div>
    </div>

    <section class="bg-white dark:bg-neutral-900 p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 mb-4">
      <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-3">Email Address</h2>
      <%= form_with url: account_path, method: :patch, class: "flex flex-col gap-3" do |f| %>
        <div class="flex flex-col gap-1.5">
          <label for="email_address" class="text-sm font-medium text-neutral-900 dark:text-neutral-100">Email</label>
          <%= f.email_field :email_address, value: @user.email_address, class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]", required: true %>
        </div>
        <div class="flex justify-end mt-1">
          <%= f.submit "Update Email", class: "px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors cursor-pointer border-none" %>
        </div>
      <% end %>
    </section>

    <section class="bg-white dark:bg-neutral-900 p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 mb-4">
      <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-3"><%= @user.incidental_password? ? "Set Password" : "Change Password" %></h2>
      <%= form_with url: account_path, method: :patch, class: "flex flex-col gap-3" do |f| %>
        <div class="flex flex-col gap-1.5">
          <label for="current_password" class="text-sm font-medium text-neutral-900 dark:text-neutral-100">Current Password</label>
          <% if @user.incidental_password? %>
            <%= f.password_field :current_password, class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]", disabled: true, placeholder: "Not required" %>
            <span class="text-xs text-neutral-500">Your account was created by <%= provider_name(@user.identities.first&.provider) %></span>
          <% else %>
            <%= f.password_field :current_password, class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]", autocomplete: "current-password" %>
          <% end %>
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="password" class="text-sm font-medium text-neutral-900 dark:text-neutral-100">New Password</label>
          <%= f.password_field :password, class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]", autocomplete: "new-password" %>
          <span class="text-xs text-neutral-500">Minimum 8 characters</span>
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="password_confirmation" class="text-sm font-medium text-neutral-900 dark:text-neutral-100">Confirm New Password</label>
          <%= f.password_field :password_confirmation, class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]", autocomplete: "new-password" %>
        </div>
        <div class="flex justify-end mt-1">
          <%= f.submit(@user.incidental_password? ? "Set Password" : "Update Password", class: "px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors cursor-pointer border-none") %>
        </div>
      <% end %>
    </section>

    <section class="bg-white dark:bg-neutral-900 p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 mb-4">
      <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Connected Accounts</h2>
      <p class="text-sm text-neutral-500 mb-3">Manage your connected login methods.</p>

      <div class="flex flex-col gap-3 mb-4">
        <% if @user.identities.any? %>
          <% @user.identities.each do |identity| %>
            <div class="flex items-center justify-between p-3 bg-neutral-50 dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700">
              <div class="flex items-center gap-3">
                <span class="flex items-center justify-center"><%= provider_icon(identity.provider) %></span>
                <span class="text-sm font-medium text-neutral-900 dark:text-neutral-100"><%= provider_name(identity.provider) %></span>
              </div>
              <% if @user.identities.count > 1 || @user.password_digest.present? %>
                <%= button_to "Disconnect", identity_account_path(identity_id: identity.id), method: :delete, class: "px-3 py-1.5 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to disconnect #{provider_name(identity.provider)}?" } %>
              <% else %>
                <span class="text-xs text-neutral-500">Set a password to disconnect</span>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-neutral-500 text-center py-3">No connected accounts.</p>
        <% end %>
      </div>

      <div class="pt-3 border-t border-neutral-200 dark:border-neutral-700">
        <p class="text-sm text-neutral-500 mb-2">Connect additional accounts:</p>
        <div class="flex gap-3 flex-wrap">
          <% unless @user.identities.exists?(provider: "google_oauth2") %>
            <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors cursor-pointer" do %>
              <%= render "shared/google_icon" %>
              <span>Google</span>
            <% end %>
          <% end %>
          <% unless @user.identities.exists?(provider: "microsoft_graph") %>
            <%= button_to "/auth/microsoft_graph", method: :post, data: { turbo: false }, class: "inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors cursor-pointer" do %>
              <%= render "shared/microsoft_icon" %>
              <span>Microsoft</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </section>

    <section class="bg-white dark:bg-neutral-900 p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 mb-4">
      <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Linked Devices</h2>
      <p class="text-sm text-neutral-500 mb-3">Apps and devices that can sync with your account.</p>

      <div class="flex flex-col gap-3">
        <% if @user.device_tokens.active.any? %>
          <% @user.device_tokens.active.order(last_used_at: :desc, created_at: :desc).each do |device_token| %>
            <div class="flex items-center justify-between p-3 bg-neutral-50 dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700">
              <div class="flex items-center gap-3">
                <span class="flex items-center justify-center"><%= device_type_icon(device_token.device_type) %></span>
                <div>
                  <span class="text-sm font-medium text-neutral-900 dark:text-neutral-100"><%= device_token.device_name %></span>
                  <div class="flex items-center gap-2 text-xs text-neutral-500">
                    <span><%= device_type_label(device_token.device_type) %></span>
                    <% if device_token.app_version.present? %>
                      <span>v<%= device_token.app_version %></span>
                    <% end %>
                    <% if device_token.last_used_at.present? %>
                      <span>Last used <%= time_ago_in_words(device_token.last_used_at) %> ago</span>
                    <% else %>
                      <span>Added <%= time_ago_in_words(device_token.created_at) %> ago</span>
                    <% end %>
                  </div>
                </div>
              </div>
              <%= button_to "Remove", account_device_token_path(device_token_id: device_token.id), method: :delete, class: "px-3 py-1.5 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors cursor-pointer", data: { turbo_confirm: "Remove #{device_token.device_name}? This device will need to sign in again." } %>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-neutral-500 text-center py-3">No linked devices.</p>
        <% end %>
      </div>
    </section>

    <section class="bg-white dark:bg-neutral-900 p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 mb-4">
      <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Log Out</h2>
      <p class="text-sm text-neutral-500 mb-3">End your session in this browser.</p>
      <div class="flex justify-end">
        <%= button_to "Log Out", session_path, method: :delete, class: "px-4 py-2 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors cursor-pointer" %>
      </div>
    </section>
  </div>
</div>
