<% assets = Releases::GithubRelease.assets %>

<dialog class="modal" data-download-modal-target="modal">
  <div class="modal-box max-w-lg">
    <header class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-bold">Download Save Button</h3>
      <form method="dialog">
        <button class="btn btn-ghost btn-sm btn-square" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </form>
    </header>

    <div>
      <%# Windows panel %>
      <div class="hidden" data-download-modal-target="panel" data-platform="windows">
        <div class="grid gap-3">
          <% if assets[:windows_msi] %>
            <a href="<%= assets[:windows_msi] %>" class="flex items-center gap-3 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition-colors">
              <img src="/icons/platforms/windows.png" alt="Windows" class="w-10 h-10">
              <div>
                <span class="font-medium block">x86 Windows Installer</span>
                <span class="text-sm opacity-60">.msi</span>
              </div>
            </a>
          <% end %>
        </div>
      </div>

      <%# macOS panel %>
      <div class="hidden" data-download-modal-target="panel" data-platform="macos">
        <div class="grid gap-3">
          <% if assets[:macos_intel] %>
            <a href="<%= assets[:macos_intel] %>" class="flex items-center gap-3 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition-colors">
              <img src="/icons/platforms/macos.png" alt="macOS" class="w-10 h-10">
              <div>
                <span class="font-medium block">Intel (x86)</span>
                <span class="text-sm opacity-60">.dmg</span>
              </div>
            </a>
          <% end %>
          <% if assets[:macos_apple_silicon] %>
            <a href="<%= assets[:macos_apple_silicon] %>" class="flex items-center gap-3 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition-colors">
              <img src="/icons/platforms/macos.png" alt="macOS" class="w-10 h-10">
              <div>
                <span class="font-medium block">Apple Silicon</span>
                <span class="text-sm opacity-60">.dmg</span>
              </div>
            </a>
          <% end %>
        </div>
      </div>

      <%# Linux panel %>
      <div class="hidden" data-download-modal-target="panel" data-platform="linux">
        <p class="text-sm opacity-70 mb-3">
          If you aren't sure which package you need for your Linux distribution, download the Flatpak.
          <a href="https://flatpak.org/setup/" class="link link-primary">Flatpaks</a> are the correct way to install apps on Linux.
        </p>
        <div class="grid gap-3">
          <a href="<%= Releases::GithubRelease::AUR_URL %>" class="flex items-center gap-3 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition-colors" target="_blank" rel="noopener noreferrer">
            <img src="/icons/platforms/arch.svg" alt="Arch Linux" class="w-10 h-10">
            <div>
              <span class="font-medium block">Arch Linux</span>
              <span class="text-sm opacity-60">AUR</span>
            </div>
          </a>
          <% if assets[:linux_deb] %>
            <a href="<%= assets[:linux_deb] %>" class="flex items-center gap-3 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition-colors">
              <img src="/icons/platforms/debian.svg" alt="Debian" class="w-10 h-10">
              <div>
                <span class="font-medium block">Debian</span>
                <span class="text-sm opacity-60">.deb</span>
              </div>
            </a>
          <% end %>
          <% if assets[:linux_rpm] %>
            <a href="<%= assets[:linux_rpm] %>" class="flex items-center gap-3 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition-colors">
              <img src="/icons/platforms/fedora.svg" alt="Fedora" class="w-10 h-10">
              <div>
                <span class="font-medium block">Fedora</span>
                <span class="text-sm opacity-60">.rpm</span>
              </div>
            </a>
          <% end %>
          <% if assets[:linux_flatpak] %>
            <a href="<%= assets[:linux_flatpak] %>" class="flex items-center gap-3 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition-colors">
              <img src="/icons/platforms/flatpak.svg" alt="Flatpak" class="w-10 h-10">
              <div>
                <span class="font-medium block">Flatpak</span>
                <span class="text-sm opacity-60">.flatpak</span>
              </div>
            </a>
          <% end %>
          <% if assets[:linux_ebuild] %>
            <a href="<%= assets[:linux_ebuild] %>" class="flex items-center gap-3 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition-colors">
              <img src="/icons/platforms/gentoo.svg" alt="Gentoo" class="w-10 h-10">
              <div>
                <span class="font-medium block">Gentoo</span>
                <span class="text-sm opacity-60">.ebuild</span>
              </div>
            </a>
          <% end %>
          <% if assets[:linux_snap] %>
            <a href="<%= assets[:linux_snap] %>" class="flex items-center gap-3 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition-colors">
              <img src="/icons/platforms/ubuntu.svg" alt="Ubuntu" class="w-10 h-10">
              <div>
                <span class="font-medium block">Ubuntu</span>
                <span class="text-sm opacity-60">.snap</span>
              </div>
            </a>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
