<div class="modal fade"
     id="addModal"
     tabindex="-1"
     aria-labelledby="addModalLabel"
     aria-hidden="true"
     data-add-modal-target="modal"
     data-action="dragover->add-modal#dragOver dragenter->add-modal#dragEnter dragleave->add-modal#dragLeave drop->add-modal#drop">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="addModalLabel">Add</h5>
        <button type="button" class="btn-close" data-action="click->add-modal#close" aria-label="Close"></button>
      </div>
      <div class="modal-body" data-add-modal-target="content">
        <div class="dropzone" data-add-modal-target="dropzone">
          <textarea class="form-control mb-2"
                    data-add-modal-target="input"
                    placeholder="Enter bookmark/note..."
                    rows="4"></textarea>
          <p class="text-body-secondary text-center small mb-0">or drop files here</p>
        </div>
        <div class="add-modal-status d-none mt-2" data-add-modal-target="status"></div>
      </div>
      <div class="modal-footer">
        <button type="button"
                class="btn btn-primary"
                data-action="click->add-modal#save"
                data-add-modal-target="saveButton">
          Save
        </button>
      </div>
    </div>
  </div>
</div>
