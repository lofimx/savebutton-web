<dialog class="modal" data-add-modal-target="modal">
  <div class="modal-box">
    <header class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-bold">Add</h3>
      <form method="dialog">
        <button class="btn btn-ghost btn-sm btn-square" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </form>
    </header>

    <div data-add-modal-target="content">
      <div data-add-modal-target="dropzone"
           data-action="dragover->add-modal#dragOver dragenter->add-modal#dragEnter dragleave->add-modal#dragLeave drop->add-modal#drop"
           class="border-2 border-dashed border-base-300 rounded-lg p-4 transition-colors">
        <textarea class="textarea textarea-bordered w-full"
                  data-add-modal-target="input"
                  placeholder="Enter bookmark/note..."
                  rows="4"></textarea>
        <p class="text-sm text-base-content/50 text-center mt-2">or drop files here</p>
      </div>

      <div class="modal-action">
        <button type="button"
                class="btn btn-primary"
                data-action="click->add-modal#save"
                data-add-modal-target="saveButton">
          Save
        </button>
      </div>

      <div class="hidden mt-2" data-add-modal-target="status"></div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
