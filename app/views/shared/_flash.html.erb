<% if flash[:notice] %>
  <div class="alert alert-success alert-dismissible fade show" role="alert" data-controller="flash" data-flash-target="message">
    <%= flash[:notice] %>
    <button type="button" class="btn-close" data-action="click->flash#dismiss" aria-label="Dismiss"></button>
  </div>
<% end %>
<% if flash[:alert] %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert" data-controller="flash" data-flash-target="message">
    <%= flash[:alert] %>
    <button type="button" class="btn-close" data-action="click->flash#dismiss" aria-label="Dismiss"></button>
  </div>
<% end %>
