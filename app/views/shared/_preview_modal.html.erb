<div class="modal-backdrop"
     data-preview-modal-target="modal"
     data-action="click->preview-modal#closeOnBackdrop keydown.esc->preview-modal#closeOnEscape"
     tabindex="-1">
  <div class="bg-white dark:bg-neutral-800 rounded-2xl border border-neutral-200 dark:border-neutral-700 shadow-lg w-full max-w-5xl max-h-[90vh] flex flex-col overflow-hidden">
    <header class="flex items-center justify-between px-4 py-2.5 border-b border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900 gap-3">
      <h2 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 m-0 overflow-hidden text-ellipsis whitespace-nowrap flex-1 min-w-0" data-preview-modal-target="title"></h2>
      <div class="flex items-center gap-3 shrink-0">
        <a href="#"
           target="_blank"
           rel="noopener noreferrer"
           class="hidden px-3 py-1.5 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors no-underline"
           data-preview-modal-target="visitLink">
          Visit original page
        </a>
        <button type="button"
                class="flex items-center justify-center w-8 h-8 p-0 bg-transparent border-none rounded-lg text-neutral-400 hover:bg-neutral-200 dark:hover:bg-neutral-700 hover:text-neutral-900 dark:hover:text-neutral-100 cursor-pointer transition-colors"
                data-action="click->preview-modal#close"
                aria-label="Close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </header>

    <div class="flex flex-1 overflow-hidden min-h-0 max-md:flex-col">
      <div class="flex-1 overflow-auto p-6 min-w-0 min-h-[200px]" data-preview-modal-target="content">
      </div>

      <aside class="preview-sidebar" data-preview-modal-target="sidebar">
        <button type="button"
                class="sidebar-toggle flex items-center gap-1.5 px-3 py-2.5 w-full text-left bg-transparent border-none border-b border-neutral-200 dark:border-neutral-700 text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100 hover:bg-neutral-200 dark:hover:bg-neutral-700 cursor-pointer text-xs transition-colors"
                data-action="click->preview-modal#toggleSidebar"
                data-preview-modal-target="sidebarToggle"
                aria-label="Toggle sidebar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 transition-transform duration-200">
            <path d="M9 18l6-6-6-6"/>
          </svg>
          <span class="sidebar-toggle-label whitespace-nowrap overflow-hidden" data-preview-modal-target="sidebarToggleLabel">Hide Sidebar</span>
        </button>

        <div class="sidebar-content flex-1 overflow-y-auto flex flex-col transition-opacity duration-100" data-preview-modal-target="sidebarContent">
          <section class="p-4 border-b border-neutral-200 dark:border-neutral-700">
            <h3 class="text-xs font-semibold text-neutral-500 uppercase tracking-wide mb-3">Tags</h3>
            <div class="flex flex-col gap-3">
              <div class="flex flex-wrap gap-1.5" data-preview-modal-target="tagsList">
              </div>
              <div class="flex gap-1.5">
                <input type="text"
                       class="flex-1 min-w-0 px-3 py-1.5 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors"
                       placeholder="Add a tag..."
                       data-preview-modal-target="tagInput"
                       data-action="keydown.enter->preview-modal#addTag">
                <button type="button"
                        class="flex items-center justify-center w-8 h-8 p-0 shrink-0 bg-primary-400 hover:bg-primary-500 text-neutral-900 border-none rounded-lg cursor-pointer text-lg font-bold transition-colors"
                        data-action="click->preview-modal#addTag"
                        aria-label="Add tag">+</button>
              </div>
            </div>
          </section>

          <section class="flex-1 flex flex-col p-4 border-b border-neutral-200 dark:border-neutral-700 min-h-[150px]">
            <h3 class="text-xs font-semibold text-neutral-500 uppercase tracking-wide mb-3">Note</h3>
            <textarea class="flex-1 w-full px-3 py-2 text-sm leading-relaxed rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors resize-none"
                      placeholder="Add a note..."
                      data-preview-modal-target="noteEditor"
                      rows="6"></textarea>
          </section>

          <div class="p-4 border-t border-neutral-200 dark:border-neutral-700 flex flex-col gap-3 mt-auto">
            <button type="button"
                    class="flex items-center justify-start gap-3 w-full px-3 py-2 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors cursor-pointer no-underline"
                    data-action="click->preview-modal#shareAnga"
                    data-preview-modal-target="shareBtn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
                <circle cx="18" cy="5" r="3"/>
                <circle cx="6" cy="12" r="3"/>
                <circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
              Share
            </button>

            <button type="button"
                    class="flex items-center justify-start gap-3 w-full px-3 py-2 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 opacity-50 cursor-not-allowed no-underline"
                    disabled
                    aria-label="Add to Space (coming soon)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
              </svg>
              Add to Space
            </button>

            <a class="flex items-center justify-start gap-3 w-full px-3 py-2 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors no-underline"
               href="#"
               download
               data-preview-modal-target="downloadLink">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download
            </a>
          </div>
        </div>
      </aside>
    </div>

    <footer class="flex justify-end gap-3 px-4 py-3 border-t border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900">
      <button type="button"
              class="px-4 py-2 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors cursor-pointer"
              data-action="click->preview-modal#cancel">
        Cancel
      </button>
      <button type="button"
              class="px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors cursor-pointer border-none"
              data-action="click->preview-modal#save"
              data-preview-modal-target="saveBtn">
        Save
      </button>
    </footer>
  </div>
</div>
