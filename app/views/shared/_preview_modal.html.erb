<div class="modal fade"
     id="previewModal"
     tabindex="-1"
     aria-labelledby="previewModalLabel"
     aria-hidden="true"
     data-preview-modal-target="modal">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-truncate" id="previewModalLabel" data-preview-modal-target="title"></h5>
        <a href="#"
           target="_blank"
           rel="noopener noreferrer"
           class="btn btn-sm btn-outline-secondary d-none me-2"
           data-preview-modal-target="visitLink">
          <i class="bi bi-box-arrow-up-right"></i> Visit
        </a>
        <button type="button" class="btn-close" data-action="click->preview-modal#close" aria-label="Close"></button>
      </div>

      <div class="modal-body p-0">
        <div class="row g-0 h-100">
          <%# Main content area %>
          <div class="col" data-preview-modal-target="content">
          </div>

          <%# Sidebar %>
          <aside class="col-md-4 border-start p-3" data-preview-modal-target="sidebar">
            <button type="button"
                    class="btn btn-sm btn-outline-secondary mb-3 d-flex align-items-center gap-1"
                    data-action="click->preview-modal#toggleSidebar"
                    data-preview-modal-target="sidebarToggle"
                    aria-label="Toggle sidebar">
              <i class="bi bi-layout-sidebar-reverse"></i>
              <span data-preview-modal-target="sidebarToggleLabel">Hide Sidebar</span>
            </button>

            <div data-preview-modal-target="sidebarContent">
              <section class="mb-3">
                <h6 class="fw-semibold">Tags</h6>
                <div class="d-flex flex-wrap gap-1 mb-2" data-preview-modal-target="tagsList">
                </div>
                <div class="input-group input-group-sm">
                  <input type="text"
                         class="form-control"
                         placeholder="Add a tag..."
                         data-preview-modal-target="tagInput"
                         data-action="keydown.enter->preview-modal#addTag">
                  <button type="button"
                          class="btn btn-outline-secondary"
                          data-action="click->preview-modal#addTag"
                          aria-label="Add tag">
                    <i class="bi bi-plus"></i>
                  </button>
                </div>
              </section>

              <section class="mb-3">
                <h6 class="fw-semibold">Note</h6>
                <textarea class="form-control"
                          placeholder="Add a note..."
                          data-preview-modal-target="noteEditor"
                          rows="4"></textarea>
              </section>

              <div class="d-flex flex-wrap gap-2">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        data-action="click->preview-modal#shareAnga"
                        data-preview-modal-target="shareBtn">
                  <i class="bi bi-share"></i> Share
                </button>

                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        disabled
                        aria-label="Add to Space (coming soon)">
                  <i class="bi bi-folder-plus"></i> Add to Space
                </button>

                <a class="btn btn-sm btn-outline-secondary"
                   href="#"
                   download
                   data-preview-modal-target="downloadLink">
                  <i class="bi bi-download"></i> Download
                </a>
              </div>
            </div>
          </aside>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button"
                class="btn btn-secondary"
                data-action="click->preview-modal#cancel">
          Cancel
        </button>
        <button type="button"
                class="btn btn-primary"
                data-action="click->preview-modal#save"
                data-preview-modal-target="saveBtn">
          Save
        </button>
      </div>
    </div>
  </div>
</div>
