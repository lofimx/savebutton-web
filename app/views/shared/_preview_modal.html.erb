<dialog class="modal" data-preview-modal-target="modal">
  <div class="modal-box max-w-5xl h-[85vh] flex flex-col p-0">
    <header class="flex items-center justify-between px-4 py-3 border-b border-base-300">
      <h3 class="text-sm font-semibold truncate flex-1 mr-4" data-preview-modal-target="title"></h3>
      <div class="flex items-center gap-2">
        <a href="#"
           target="_blank"
           rel="noopener noreferrer"
           class="btn btn-ghost btn-sm hidden"
           data-preview-modal-target="visitLink">
          Visit original page
        </a>
        <form method="dialog">
          <button class="btn btn-ghost btn-sm btn-square" aria-label="Close">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </form>
      </div>
    </header>

    <div class="flex flex-1 overflow-hidden">
      <div class="flex-1 overflow-auto p-4" data-preview-modal-target="content">
      </div>

      <div class="flex" data-preview-modal-target="sidebarWrapper">
        <%# Toggle button — always visible, lives outside the collapsible aside %>
        <button type="button"
                class="btn btn-ghost btn-xs h-auto px-0.5 rounded-none border-l border-base-300 flex items-center"
                data-action="click->preview-modal#toggleSidebar"
                data-preview-modal-target="sidebarToggle"
                aria-label="Toggle sidebar"
                title="Toggle sidebar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               data-preview-modal-target="sidebarToggleIcon">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>

        <aside class="w-72 border-l border-base-300 flex flex-col overflow-auto transition-all" data-preview-modal-target="sidebar">
          <div class="p-4 flex flex-col gap-4" data-preview-modal-target="sidebarContent">
            <section>
              <h4 class="text-sm font-semibold mb-2">Tags</h4>
              <div class="flex flex-wrap gap-1 mb-2" data-preview-modal-target="tagsList">
              </div>
              <div class="flex gap-1">
                <input type="text"
                       class="input input-bordered input-sm flex-1"
                       placeholder="Add a tag..."
                       data-preview-modal-target="tagInput"
                       data-action="keydown.enter->preview-modal#addTag">
                <button type="button"
                        class="btn btn-ghost btn-sm btn-square"
                        data-action="click->preview-modal#addTag"
                        aria-label="Add tag">+</button>
              </div>
            </section>

            <section>
              <h4 class="text-sm font-semibold mb-2">Note</h4>
              <textarea class="textarea textarea-bordered w-full text-sm"
                        placeholder="Add a note..."
                        data-preview-modal-target="noteEditor"
                        rows="4"></textarea>
            </section>

            <div class="flex flex-col gap-2">
              <button type="button"
                      class="btn btn-ghost btn-sm justify-start gap-2"
                      data-action="click->preview-modal#shareAnga"
                      data-preview-modal-target="shareBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="18" cy="5" r="3"/>
                  <circle cx="6" cy="12" r="3"/>
                  <circle cx="18" cy="19" r="3"/>
                  <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                  <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                </svg>
                Share
              </button>

              <button type="button"
                      class="btn btn-ghost btn-sm justify-start gap-2"
                      disabled
                      aria-label="Add to Space (coming soon)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
                Add to Space
              </button>

              <a class="btn btn-ghost btn-sm justify-start gap-2"
                 href="#"
                 download
                 data-preview-modal-target="downloadLink">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Download
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>

    <footer class="flex justify-end gap-2 px-4 py-3 border-t border-base-300">
      <button type="button"
              class="btn btn-ghost"
              data-action="click->preview-modal#cancel">
        Cancel
      </button>
      <button type="button"
              class="btn btn-primary"
              data-action="click->preview-modal#save"
              data-preview-modal-target="saveBtn">
        Save
      </button>
    </footer>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
