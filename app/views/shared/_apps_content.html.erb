<section class="mb-5">
  <h4 class="fw-semibold mb-2">Mobile Apps</h4>
  <p class="text-body-secondary">Available for iPhone, iPad, Android phones, and Android tablets.</p>
  <div class="d-flex flex-wrap gap-3">
    <a href="https://apps.apple.com/app/save-button-app/id6758891680" target="_blank" rel="noopener noreferrer">
      <img src="/icons/platforms/app-store.svg" alt="Download on the App Store" class="store-badge">
    </a>
    <a href="https://play.google.com/store/apps/details?id=org.savebutton.app" target="_blank" rel="noopener noreferrer">
      <img src="/icons/platforms/play-store.svg" alt="Get it on Google Play" class="store-badge">
    </a>
  </div>
</section>

<section class="mb-5">
  <h4 class="fw-semibold mb-2">Browser Extensions</h4>
  <p class="text-body-secondary">Save Button works on most browsers. If your browser is not listed, try installing from the Chromium link.</p>
  <div class="row row-cols-2 row-cols-sm-4 row-cols-md-4 row-cols-lg-8 g-3">
    <div class="col text-center">
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="text-decoration-none text-body" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/chrome.png" alt="Chrome" class="browser-icon mb-1">
        <div class="small">Chrome</div>
      </a>
    </div>
    <div class="col text-center">
      <a href="https://addons.mozilla.org/en-US/firefox/addon/save-button/" class="text-decoration-none text-body" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/firefox.png" alt="Firefox" class="browser-icon mb-1">
        <div class="small">Firefox</div>
      </a>
    </div>
    <div class="col text-center">
      <a href="https://microsoftedge.microsoft.com/addons/detail/save-button/ldcpchibphbafmclockfeoiffafjdekj" class="text-decoration-none text-body" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/edge.png" alt="Edge" class="browser-icon mb-1">
        <div class="small">Edge</div>
      </a>
    </div>
    <div class="col text-center">
      <a href="https://apps.apple.com/app/save-button-for-safari/id6759535767" class="text-decoration-none text-body" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/safari.png" alt="Safari" class="browser-icon mb-1">
        <div class="small">Safari</div>
      </a>
    </div>
    <div class="col text-center">
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="text-decoration-none text-body" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/chromium.png" alt="Chromium" class="browser-icon mb-1">
        <div class="small">Chromium</div>
      </a>
    </div>
    <div class="col text-center">
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="text-decoration-none text-body" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/brave.png" alt="Brave" class="browser-icon mb-1">
        <div class="small">Brave</div>
      </a>
    </div>
    <div class="col text-center">
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="text-decoration-none text-body" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/vivaldi.png" alt="Vivaldi" class="browser-icon mb-1">
        <div class="small">Vivaldi</div>
      </a>
    </div>
    <div class="col text-center">
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="text-decoration-none text-body" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/arc.png" alt="Arc" class="browser-icon mb-1">
        <div class="small">Arc</div>
      </a>
    </div>
  </div>
</section>

<section class="mb-5" data-controller="download-modal">
  <h4 class="fw-semibold mb-2">Desktop Apps</h4>
  <div class="d-flex flex-wrap gap-3">
    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-2" data-action="click->download-modal#open" data-download-platform="windows">
      <img src="/icons/platforms/windows.png" alt="Windows" class="platform-icon" style="width:24px;height:24px;">
      Windows
    </button>
    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-2" data-action="click->download-modal#open" data-download-platform="macos">
      <img src="/icons/platforms/macos.png" alt="macOS" class="platform-icon" style="width:24px;height:24px;">
      macOS
    </button>
    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-2" data-action="click->download-modal#open" data-download-platform="linux">
      <img src="/icons/platforms/linux.png" alt="Linux" class="platform-icon" style="width:24px;height:24px;">
      Linux
    </button>
  </div>

  <%= render "shared/download_modal" %>
</section>

<section class="mb-5">
  <h4 class="fw-semibold mb-2">Service</h4>
  <p class="text-body-secondary">Grab an account with savebutton.com or, if you're a big nerd, <a href="#nerd-features">host it yourself</a>.</p>
  <% if authenticated? %>
    <span class="btn btn-primary disabled">You're already logged in!</span>
  <% else %>
    <%= link_to "Sign Up", new_registration_path, class: "btn btn-primary" %>
  <% end %>
</section>
