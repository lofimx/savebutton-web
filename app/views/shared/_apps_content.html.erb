<div class="flex flex-col gap-3">
  <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">Mobile Apps</h3>
  <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">Available for iPhone, iPad, Android phones, and Android tablets.</p>
  <div class="flex gap-3 flex-wrap">
    <a href="https://apps.apple.com/app/save-button-app/id6758891680" class="inline-block hover:-translate-y-0.5 transition-transform" target="_blank" rel="noopener noreferrer">
      <img src="/icons/platforms/app-store.svg" alt="Download on the App Store" class="h-[60px] w-auto block">
    </a>
    <a href="https://play.google.com/store/apps/details?id=org.savebutton.app" class="inline-block hover:-translate-y-0.5 transition-transform" target="_blank" rel="noopener noreferrer">
      <img src="/icons/platforms/play-store.svg" alt="Get it on Google Play" class="h-[60px] w-auto block">
    </a>
  </div>
</div>

<div class="flex flex-col gap-3">
  <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">Browser Extensions</h3>
  <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">Save Button works on most browsers. If your browser is not listed, try installing from the Chromium link.</p>
  <div class="grid grid-cols-4 gap-3 mt-2 max-sm:grid-cols-2">
    <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1.5 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg no-underline border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all" target="_blank" rel="noopener noreferrer">
      <img src="/icons/browsers/chrome.png" alt="Chrome" class="w-16 h-16 object-contain">
      <span class="text-xs font-medium text-neutral-900 dark:text-neutral-100 text-center">Chrome</span>
    </a>
    <a href="https://addons.mozilla.org/en-US/firefox/addon/save-button/" class="flex flex-col items-center gap-1.5 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg no-underline border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all" target="_blank" rel="noopener noreferrer">
      <img src="/icons/browsers/firefox.png" alt="Firefox" class="w-16 h-16 object-contain">
      <span class="text-xs font-medium text-neutral-900 dark:text-neutral-100 text-center">Firefox</span>
    </a>
    <a href="https://microsoftedge.microsoft.com/addons/detail/save-button/ldcpchibphbafmclockfeoiffafjdekj" class="flex flex-col items-center gap-1.5 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg no-underline border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all" target="_blank" rel="noopener noreferrer">
      <img src="/icons/browsers/edge.png" alt="Edge" class="w-16 h-16 object-contain">
      <span class="text-xs font-medium text-neutral-900 dark:text-neutral-100 text-center">Edge</span>
    </a>
    <a href="https://apps.apple.com/app/save-button-for-safari/id6759535767" class="flex flex-col items-center gap-1.5 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg no-underline border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all" target="_blank" rel="noopener noreferrer">
      <img src="/icons/browsers/safari.png" alt="Safari" class="w-16 h-16 object-contain">
      <span class="text-xs font-medium text-neutral-900 dark:text-neutral-100 text-center">Safari</span>
    </a>
    <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1.5 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg no-underline border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all" target="_blank" rel="noopener noreferrer">
      <img src="/icons/browsers/chromium.png" alt="Chromium" class="w-16 h-16 object-contain">
      <span class="text-xs font-medium text-neutral-900 dark:text-neutral-100 text-center">Chromium</span>
    </a>
    <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1.5 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg no-underline border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all" target="_blank" rel="noopener noreferrer">
      <img src="/icons/browsers/brave.png" alt="Brave" class="w-16 h-16 object-contain">
      <span class="text-xs font-medium text-neutral-900 dark:text-neutral-100 text-center">Brave</span>
    </a>
    <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1.5 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg no-underline border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all" target="_blank" rel="noopener noreferrer">
      <img src="/icons/browsers/vivaldi.png" alt="Vivaldi" class="w-16 h-16 object-contain">
      <span class="text-xs font-medium text-neutral-900 dark:text-neutral-100 text-center">Vivaldi</span>
    </a>
    <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1.5 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg no-underline border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all" target="_blank" rel="noopener noreferrer">
      <img src="/icons/browsers/arc.png" alt="Arc" class="w-16 h-16 object-contain">
      <span class="text-xs font-medium text-neutral-900 dark:text-neutral-100 text-center">Arc</span>
    </a>
  </div>
</div>

<div class="flex flex-col gap-3" data-controller="download-modal">
  <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">Desktop Apps</h3>
  <div class="flex flex-row gap-3 mt-2 max-sm:flex-col">
    <button type="button" class="flex-1 flex items-center gap-3 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all cursor-pointer font-[inherit] text-[inherit] text-left" data-action="click->download-modal#open" data-download-platform="windows">
      <img src="/icons/platforms/windows.png" alt="Windows" class="w-12 h-12 object-contain shrink-0">
      <div class="flex flex-col gap-0.5">
        <span class="text-sm font-medium text-neutral-900 dark:text-neutral-100">Windows</span>
      </div>
    </button>
    <button type="button" class="flex-1 flex items-center gap-3 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all cursor-pointer font-[inherit] text-[inherit] text-left" data-action="click->download-modal#open" data-download-platform="macos">
      <img src="/icons/platforms/macos.png" alt="macOS" class="w-12 h-12 object-contain shrink-0">
      <div class="flex flex-col gap-0.5">
        <span class="text-sm font-medium text-neutral-900 dark:text-neutral-100">macOS</span>
      </div>
    </button>
    <button type="button" class="flex-1 flex items-center gap-3 p-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg border border-transparent hover:bg-white dark:hover:bg-neutral-900 hover:border-primary-400 hover:-translate-y-0.5 transition-all cursor-pointer font-[inherit] text-[inherit] text-left" data-action="click->download-modal#open" data-download-platform="linux">
      <img src="/icons/platforms/linux.png" alt="Linux" class="w-12 h-12 object-contain shrink-0">
      <div class="flex flex-col gap-0.5">
        <span class="text-sm font-medium text-neutral-900 dark:text-neutral-100">Linux</span>
      </div>
    </button>
  </div>

  <%= render "shared/download_modal" %>
</div>

<div class="flex flex-col gap-3">
  <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">Service</h3>
  <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">Grab an account with savebutton.com or, if you're a big nerd, <a href="#nerd-features">host it yourself</a>.</p>
  <div class="flex gap-4 mt-4">
    <div>
      <% if authenticated? %>
        <span class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 text-neutral-900 opacity-50 cursor-not-allowed">You're already logged in!</span>
      <% else %>
        <%= link_to "Sign Up", new_registration_path, class: "inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors no-underline" %>
      <% end %>
    </div>
  </div>
</div>
