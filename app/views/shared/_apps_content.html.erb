<div class="space-y-8">
  <div>
    <h3 class="text-lg font-semibold mb-2">Mobile Apps</h3>
    <p class="text-sm opacity-70 mb-4">Available for iPhone, iPad, Android phones, and Android tablets.</p>
    <div class="flex flex-wrap gap-4">
      <a href="https://apps.apple.com/app/save-button-app/id6758891680" class="block" target="_blank" rel="noopener noreferrer">
        <img src="/icons/platforms/app-store.svg" alt="Download on the App Store" class="h-10">
      </a>
      <a href="https://play.google.com/store/apps/details?id=org.savebutton.app" class="block" target="_blank" rel="noopener noreferrer">
        <img src="/icons/platforms/play-store.svg" alt="Get it on Google Play" class="h-10">
      </a>
    </div>
  </div>

  <div>
    <h3 class="text-lg font-semibold mb-2">Browser Extensions</h3>
    <p class="text-sm opacity-70 mb-4">Save Button works on most browsers. If your browser is not listed, try installing from the Chromium link.</p>
    <div class="grid grid-cols-4 sm:grid-cols-8 gap-4">
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/chrome.png" alt="Chrome" class="w-10 h-10">
        <span class="text-xs">Chrome</span>
      </a>
      <a href="https://addons.mozilla.org/en-US/firefox/addon/save-button/" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/firefox.png" alt="Firefox" class="w-10 h-10">
        <span class="text-xs">Firefox</span>
      </a>
      <a href="https://microsoftedge.microsoft.com/addons/detail/save-button/ldcpchibphbafmclockfeoiffafjdekj" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/edge.png" alt="Edge" class="w-10 h-10">
        <span class="text-xs">Edge</span>
      </a>
      <a href="https://apps.apple.com/app/save-button-for-safari/id6759535767" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/safari.png" alt="Safari" class="w-10 h-10">
        <span class="text-xs">Safari</span>
      </a>
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/chromium.png" alt="Chromium" class="w-10 h-10">
        <span class="text-xs">Chromium</span>
      </a>
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/brave.png" alt="Brave" class="w-10 h-10">
        <span class="text-xs">Brave</span>
      </a>
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/vivaldi.png" alt="Vivaldi" class="w-10 h-10">
        <span class="text-xs">Vivaldi</span>
      </a>
      <a href="https://chromewebstore.google.com/detail/save-button/eeoleaffndkjkgbdhaojcgehcklfihid" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity" target="_blank" rel="noopener noreferrer">
        <img src="/icons/browsers/arc.png" alt="Arc" class="w-10 h-10">
        <span class="text-xs">Arc</span>
      </a>
    </div>
  </div>

  <div data-controller="download-modal">
    <h3 class="text-lg font-semibold mb-2">Desktop Apps</h3>
    <div class="grid grid-cols-3 gap-4 max-w-sm">
      <button type="button" class="btn btn-ghost flex-col h-auto py-4 gap-2" data-action="click->download-modal#open" data-download-platform="windows">
        <img src="/icons/platforms/windows.png" alt="Windows" class="w-10 h-10">
        <span class="text-xs">Windows</span>
      </button>
      <button type="button" class="btn btn-ghost flex-col h-auto py-4 gap-2" data-action="click->download-modal#open" data-download-platform="macos">
        <img src="/icons/platforms/macos.png" alt="macOS" class="w-10 h-10">
        <span class="text-xs">macOS</span>
      </button>
      <button type="button" class="btn btn-ghost flex-col h-auto py-4 gap-2" data-action="click->download-modal#open" data-download-platform="linux">
        <img src="/icons/platforms/linux.png" alt="Linux" class="w-10 h-10">
        <span class="text-xs">Linux</span>
      </button>
    </div>

    <%= render "shared/download_modal" %>
  </div>

  <div>
    <h3 class="text-lg font-semibold mb-2">Service</h3>
    <p class="text-sm opacity-70 mb-4">Grab an account with savebutton.com or, if you're a big nerd, <a href="#nerd-features" class="link link-primary">host it yourself</a>.</p>
    <% if authenticated? %>
      <span class="btn btn-primary btn-disabled">You're already logged in!</span>
    <% else %>
      <%= link_to "Sign Up", new_registration_path, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
