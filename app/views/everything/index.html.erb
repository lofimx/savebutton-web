<% content_for :app_layout, true %>

<div class="max-w-6xl mx-auto px-4 py-4" data-controller="preview-modal">
  <div class="mb-4">
    <%= form_with url: app_everything_path, method: :get, data: { controller: "search", turbo_frame: "anga-results" } do |f| %>
      <input type="search"
             name="q"
             value="<%= params[:q] %>"
             placeholder="Search your cards..."
             autocomplete="off"
             class="input input-bordered w-full"
             autofocus
             data-search-target="input"
             data-action="input->search#search keydown.enter->search#submit">
    <% end %>
  </div>

  <%= turbo_frame_tag "anga-results" do %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      <% @angas.each do |anga| %>
        <%
          file_type = Files::FileType.new(anga.filename)
          original_url = anga.bookmark_url if file_type.bookmark?
          cache_url = if file_type.bookmark? && anga.bookmark&.cached?
                        app_anga_cache_file_path(anga, "index.html")
                      end
          cache_status_url = if file_type.bookmark?
                               app_anga_cache_status_path(anga)
                             end
        %>
        <div class="flex flex-col bg-base-100 rounded-lg shadow-sm cursor-pointer hover:shadow-md transition-shadow p-3"
             style="height: 100%"
             id="anga-tile-<%= anga.id %>"
             data-action="click->preview-modal#open"
             data-preview-url="<%= app_anga_preview_path(anga) %>"
             data-preview-filename="<%= anga.filename %>"
             data-preview-type="<%= file_type.preview_type %>"
             data-anga-id="<%= anga.id %>"
             data-meta-url="<%= app_anga_meta_path(anga) %>"
             data-save-meta-url="<%= app_anga_save_meta_path(anga) %>"
             data-share-url="<%= share_anga_url(user_id: Current.user.id, filename: anga.filename) %>"
             <%= "data-preview-original-url=#{original_url}" if original_url %>
             <%= "data-preview-cache-url=#{cache_url}" if cache_url %>
             <%= "data-cache-status-url=#{cache_status_url}" if cache_status_url %>>
          <div style="flex:1 1 0%">
            <% if file_type.note? || file_type.text? %>
              <div class="text-xs opacity-70 line-clamp-6 whitespace-pre-wrap"><% if anga.file.attached? %><%= anga.file.download.force_encoding('UTF-8').truncate(500).strip %><% end %></div>
            <% elsif file_type.bookmark? %>
              <div class="flex items-center justify-center h-16" data-controller="favicon-fallback">
                <% if anga.bookmark&.favicon&.attached? %>
                  <%= image_tag app_anga_cache_file_path(anga, "favicon.ico"), class: "w-10 h-10", alt: "Favicon", data: { action: "error->favicon-fallback#showDefault" } %>
                  <template data-favicon-fallback-target="fallback">
                    <%= render "shared/icons/bookmark_icon" %>
                  </template>
                <% else %>
                  <%= render "shared/icons/bookmark_icon" %>
                <% end %>
              </div>
            <% elsif file_type.image? %>
              <div class="h-24 overflow-hidden rounded">
                <%= image_tag app_anga_preview_path(anga), alt: anga.filename, class: "w-full h-full object-cover" %>
              </div>
            <% elsif file_type.pdf? %>
              <div class="flex items-center justify-center h-16">
                <%= render "shared/icons/pdf_icon" %>
              </div>
            <% else %>
              <div class="flex items-center justify-center h-16">
                <span class="text-lg font-bold opacity-40"><%= file_type.extension_name.upcase %></span>
              </div>
            <% end %>
          </div>
          <p class="text-xs truncate opacity-60 mt-1"><%= file_type.bookmark? && original_url.present? ? original_url : display_filename(anga.filename) %></p>
        </div>
      <% end %>
    </div>

    <% if @angas.empty? %>
      <div class="text-center py-16 opacity-60" data-testid="empty-state">
        <% if params[:q].present? %>
          <p>No results found.</p>
        <% else %>
          <p>No files yet. Start adding notes and bookmarks!</p>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render "shared/preview_modal" %>
</div>
