<% content_for(:title) { "Set New Password - Save Button" } %>
<% content_for(:hide_header) { true } %>

<div class="min-h-screen flex flex-col bg-neutral-50 dark:bg-neutral-950">
  <div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-sm bg-white dark:bg-neutral-900 p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 shadow-lg">
      <div class="text-center mb-6">
        <%= link_to root_path, class: "inline-flex items-center gap-1.5 no-underline mb-4" do %>
          <%= render "shared/logo_icon", size: 36, id_suffix: "auth-reset" %>
          <span class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 tracking-tight">Save Button</span>
        <% end %>
        <h1 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-1">Set a new password</h1>
        <p class="text-sm text-neutral-500">Enter your new password below</p>
      </div>

      <% if flash[:alert] %>
        <div class="px-3 py-2 rounded-lg text-sm mb-3 bg-red-100 text-red-700 border border-red-200 dark:bg-red-500/15 dark:text-red-400 dark:border-red-500/30"><%= flash[:alert] %></div>
      <% end %>

      <%= form_with url: password_path(params[:token]), method: :put, class: "flex flex-col gap-3" do |form| %>
        <div class="flex flex-col gap-1.5">
          <%= form.label :password, "New password", class: "text-sm font-medium text-neutral-900 dark:text-neutral-100" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "At least 8 characters", minlength: 8, maxlength: 72, class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]" %>
          <span class="text-xs text-neutral-500">Must be at least 8 characters</span>
        </div>

        <div class="flex flex-col gap-1.5">
          <%= form.label :password_confirmation, "Confirm new password", class: "text-sm font-medium text-neutral-900 dark:text-neutral-100" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Enter your password again", maxlength: 72, class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]" %>
        </div>

        <%= form.submit "Update password", class: "w-full px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors cursor-pointer border-none" %>
      <% end %>

      <p class="text-center mt-4 text-sm text-neutral-500">
        <%= link_to "Back to login", new_session_path %>
      </p>
    </div>
  </div>
</div>
