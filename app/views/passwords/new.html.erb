<% content_for(:title) { "Reset Password - Save Button" } %>
<% content_for(:hide_header) { true } %>

<div class="min-h-screen flex flex-col bg-neutral-50 dark:bg-neutral-950">
  <div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-sm bg-white dark:bg-neutral-900 p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 shadow-lg">
      <div class="text-center mb-6">
        <%= link_to root_path, class: "inline-flex items-center gap-1.5 no-underline mb-4" do %>
          <%= render "shared/logo_icon", size: 36, id_suffix: "auth-forgot" %>
          <span class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 tracking-tight">Save Button</span>
        <% end %>
        <h1 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-1">Forgot your password?</h1>
        <p class="text-sm text-neutral-500">Enter your email and we'll send you reset instructions</p>
      </div>

      <% if flash[:alert] %>
        <div class="px-3 py-2 rounded-lg text-sm mb-3 bg-red-100 text-red-700 border border-red-200 dark:bg-red-500/15 dark:text-red-400 dark:border-red-500/30"><%= flash[:alert] %></div>
      <% end %>
      <% if flash[:notice] %>
        <div class="px-3 py-2 rounded-lg text-sm mb-3 bg-green-100 text-green-700 border border-green-200 dark:bg-green-500/15 dark:text-green-400 dark:border-green-500/30"><%= flash[:notice] %></div>
      <% end %>

      <%= form_with url: passwords_path, class: "flex flex-col gap-3" do |form| %>
        <div class="flex flex-col gap-1.5">
          <%= form.label :email_address, "Email address", class: "text-sm font-medium text-neutral-900 dark:text-neutral-100" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "you@example.com", value: params[:email_address], class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]" %>
        </div>

        <%= form.submit "Send reset instructions", class: "w-full px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors cursor-pointer border-none" %>
      <% end %>

      <p class="text-center mt-4 text-sm text-neutral-500">
        Remember your password? <%= link_to "Log in", new_session_path %>
      </p>
    </div>
  </div>
</div>
