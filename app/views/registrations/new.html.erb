<% content_for(:title) { "Sign Up - Save Button" } %>
<% content_for(:hide_header) { true } %>

<div class="auth-page">
  <div class="card shadow-sm" style="max-width: 420px; width: 100%;">
    <div class="card-body p-4">
      <h1 class="h4 text-center mb-4">Create your account</h1>

      <% if flash[:alert] %>
        <div class="alert alert-danger"><%= flash[:alert] %></div>
      <% end %>
      <% if flash[:notice] %>
        <div class="alert alert-success"><%= flash[:notice] %></div>
      <% end %>

      <div class="d-grid gap-2 mb-3">
        <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "btn-oauth" do %>
          <%= render "shared/google_icon" %>
          Sign up with Google
        <% end %>

        <%= button_to "/auth/microsoft_graph", method: :post, data: { turbo: false }, class: "btn-oauth" do %>
          <%= render "shared/microsoft_icon" %>
          Sign up with Microsoft
        <% end %>

        <button type="button" class="btn-oauth" disabled>
          <%= render "shared/apple_icon" %>
          Sign up with Apple
          <span class="coming-soon">Coming soon</span>
        </button>
      </div>

      <div class="d-flex align-items-center gap-3 my-4">
        <hr class="flex-grow-1">
        <span class="text-body-secondary small">or</span>
        <hr class="flex-grow-1">
      </div>

      <%= form_with model: @user, url: registration_path do |form| %>
        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= form.label :email_address, "Email address", class: "form-label" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.label :password, "Password", class: "form-label" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "At least 8 characters", minlength: 8, class: "form-control" %>
          <div class="form-text">Must be at least 8 characters</div>
        </div>

        <div class="mb-3">
          <%= form.label :password_confirmation, "Confirm password", class: "form-label" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Enter your password again", class: "form-control" %>
        </div>

        <%= form.submit "Create account", class: "btn btn-primary w-100" %>
      <% end %>

      <p class="text-center mt-3 mb-0 small">
        Already have an account? <%= link_to "Log in", new_session_path %>
      </p>
    </div>
  </div>
</div>
