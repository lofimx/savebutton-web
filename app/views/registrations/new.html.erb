<% content_for(:title) { "Sign Up - Save Button" } %>
<% content_for(:hide_header) { true } %>

<div class="min-h-screen flex flex-col bg-neutral-50 dark:bg-neutral-950">
  <div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-sm bg-white dark:bg-neutral-900 p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 shadow-lg">
      <div class="text-center mb-6">
        <h1 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">Create your account</h1>
      </div>

      <% if flash[:alert] %>
        <div class="px-3 py-2 rounded-lg text-sm mb-3 bg-red-100 text-red-700 border border-red-200 dark:bg-red-500/15 dark:text-red-400 dark:border-red-500/30"><%= flash[:alert] %></div>
      <% end %>
      <% if flash[:notice] %>
        <div class="px-3 py-2 rounded-lg text-sm mb-3 bg-green-100 text-green-700 border border-green-200 dark:bg-green-500/15 dark:text-green-400 dark:border-green-500/30"><%= flash[:notice] %></div>
      <% end %>

      <div class="flex flex-col gap-1.5 mb-4">
        <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "w-full inline-flex items-center justify-center gap-2 px-3 py-2.5 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors cursor-pointer min-h-[44px]" do %>
          <%= render "shared/google_icon" %>
          Sign up with Google
        <% end %>

        <%= button_to "/auth/microsoft_graph", method: :post, data: { turbo: false }, class: "w-full inline-flex items-center justify-center gap-2 px-3 py-2.5 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors cursor-pointer min-h-[44px]" do %>
          <%= render "shared/microsoft_icon" %>
          Sign up with Microsoft
        <% end %>

        <button type="button" class="w-full inline-flex items-center justify-center gap-2 px-3 py-2.5 text-sm font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 opacity-50 cursor-not-allowed min-h-[44px]" disabled>
          <%= render "shared/apple_icon" %>
          Sign up with Apple
          <span class="text-xs text-neutral-500 bg-neutral-100 dark:bg-neutral-700 px-2 py-0.5 rounded-full ml-auto">Coming soon</span>
        </button>
      </div>

      <div class="flex items-center gap-3 mb-4">
        <div class="flex-1 h-px bg-neutral-200 dark:bg-neutral-700"></div>
        <span class="text-neutral-500 text-sm">or</span>
        <div class="flex-1 h-px bg-neutral-200 dark:bg-neutral-700"></div>
      </div>

      <%= form_with model: @user, url: registration_path, class: "flex flex-col gap-3" do |form| %>
        <% if @user.errors.any? %>
          <div class="px-3 py-2 rounded-lg text-sm bg-red-100 text-red-700 border border-red-200 dark:bg-red-500/15 dark:text-red-400 dark:border-red-500/30">
            <ul class="list-none m-0 p-0">
              <% @user.errors.full_messages.each do |message| %>
                <li class="py-1 first:pt-0 last:pb-0"><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="flex flex-col gap-1.5">
          <%= form.label :email_address, "Email address", class: "text-sm font-medium text-neutral-900 dark:text-neutral-100" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]" %>
        </div>

        <div class="flex flex-col gap-1.5">
          <%= form.label :password, "Password", class: "text-sm font-medium text-neutral-900 dark:text-neutral-100" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "At least 8 characters", minlength: 8, class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]" %>
          <span class="text-xs text-neutral-500">Must be at least 8 characters</span>
        </div>

        <div class="flex flex-col gap-1.5">
          <%= form.label :password_confirmation, "Confirm password", class: "text-sm font-medium text-neutral-900 dark:text-neutral-100" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Enter your password again", class: "w-full px-3 py-2 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition-colors min-h-[40px]" %>
        </div>

        <%= form.submit "Create account", class: "w-full px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors cursor-pointer border-none" %>
      <% end %>

      <p class="text-center mt-4 text-sm text-neutral-500">
        Already have an account? <%= link_to "Log in", new_session_path %>
      </p>
    </div>
  </div>
</div>
