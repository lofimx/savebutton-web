<% content_for(:title) { "Sign Up - Save Button" } %>
<% content_for(:hide_header) { true } %>

<div class="min-h-screen flex items-center justify-center bg-base-200 px-4">
  <div class="card bg-base-100 shadow-xl w-full max-w-sm">
    <div class="card-body">
      <h1 class="text-2xl font-bold text-center mb-2">Create your account</h1>

      <% if flash[:alert] %>
        <div class="alert alert-error text-sm"><span><%= flash[:alert] %></span></div>
      <% end %>
      <% if flash[:notice] %>
        <div class="alert alert-success text-sm"><span><%= flash[:notice] %></span></div>
      <% end %>

      <div class="space-y-2 mb-2">
        <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "btn btn-outline w-full gap-2" do %>
          <%= render "shared/google_icon" %>
          Sign up with Google
        <% end %>

        <%= button_to "/auth/microsoft_graph", method: :post, data: { turbo: false }, class: "btn btn-outline w-full gap-2" do %>
          <%= render "shared/microsoft_icon" %>
          Sign up with Microsoft
        <% end %>

        <button type="button" class="btn btn-outline w-full gap-2" disabled>
          <%= render "shared/apple_icon" %>
          Sign up with Apple
          <span class="badge badge-sm">Soon</span>
        </button>
      </div>

      <div class="divider text-sm">or</div>

      <%= form_with model: @user, url: registration_path do |form| %>
        <% if @user.errors.any? %>
          <div class="alert alert-error text-sm mb-3">
            <div>
              <ul class="list-disc list-inside">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>

        <div class="space-y-3">
          <div>
            <label class="text-sm opacity-60 mb-1 block">Email address</label>
            <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "input input-bordered w-full" %>
          </div>

          <div>
            <label class="text-sm opacity-60 mb-1 block">Password</label>
            <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "At least 8 characters", minlength: 8, class: "input input-bordered w-full" %>
            <p class="text-xs opacity-50 mt-1">Must be at least 8 characters</p>
          </div>

          <div>
            <label class="text-sm opacity-60 mb-1 block">Confirm password</label>
            <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Enter your password again", class: "input input-bordered w-full" %>
          </div>

          <%= form.submit "Create account", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <p class="text-center text-sm mt-4">
        Already have an account? <%= link_to "Log in", new_session_path, class: "link link-primary" %>
      </p>
    </div>
  </div>
</div>
