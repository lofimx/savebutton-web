<% content_for(:title) { "Log In - Save Button" } %>
<% content_for(:hide_header) { true } %>

<div class="auth-page">
  <div class="card shadow-sm" style="max-width: 420px; width: 100%;">
    <div class="card-body p-4">
      <h1 class="h4 text-center mb-4">Welcome Back</h1>

      <% if flash[:alert] %>
        <div class="alert alert-danger"><%= flash[:alert] %></div>
      <% end %>
      <% if flash[:notice] %>
        <div class="alert alert-success"><%= flash[:notice] %></div>
      <% end %>

      <div class="d-grid gap-2 mb-3">
        <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "btn-oauth" do %>
          <%= render "shared/google_icon" %>
          Log in with Google
        <% end %>

        <%= button_to "/auth/microsoft_graph", method: :post, data: { turbo: false }, class: "btn-oauth" do %>
          <%= render "shared/microsoft_icon" %>
          Log in with Microsoft
        <% end %>

        <button type="button" class="btn-oauth" disabled>
          <%= render "shared/apple_icon" %>
          Log in with Apple
          <span class="coming-soon">Coming soon</span>
        </button>
      </div>

      <div class="d-flex align-items-center gap-3 my-4">
        <hr class="flex-grow-1">
        <span class="text-body-secondary small">or</span>
        <hr class="flex-grow-1">
      </div>

      <%= form_with url: session_path do |form| %>
        <div class="mb-3">
          <%= form.label :email_address, "Email address", class: "form-label" %>
          <%= form.email_field :email_address, required: true, autofocus: params[:email_address].blank?, autocomplete: "username", placeholder: "you@example.com", value: params[:email_address], class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.label :password, "Password", class: "form-label" %>
          <%= form.password_field :password, required: true, autofocus: params[:email_address].present?, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "form-control" %>
        </div>

        <div class="mb-3 text-end">
          <%= link_to "Forgot password?", new_password_path, class: "small" %>
        </div>

        <%= form.submit "Log in", class: "btn btn-primary w-100" %>
      <% end %>

      <p class="text-center mt-3 mb-0 small">
        Don't have an account? <%= link_to "Sign up", new_registration_path %>
      </p>
    </div>
  </div>
</div>
