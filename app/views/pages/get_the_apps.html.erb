<% if authenticated? %>
  <% content_for :app_layout, true %>
  <% content_for :hide_add_button, true %>
<% else %>
  <% content_for(:title) { "Save Button - Save Notes & Bookmarks" } %>
<% end %>

<div class="max-w-5xl mx-auto pt-[calc(60px+1.5rem)] px-6 pb-6">
  <section class="py-16">
    <h2 class="text-3xl font-bold text-center mb-12 tracking-tight text-neutral-900 dark:text-neutral-100">Get The Apps</h2>
    <div class="flex flex-col gap-12">
      <%= render "shared/apps_content" %>
    </div>
  </section>
</div>
