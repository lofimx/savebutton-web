<% content_for(:title) { "Save Button - Save Notes & Bookmarks" } %>

<div class="bg-body-tertiary py-5">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <h1 class="display-4 fw-bold mb-3">
          Save stuff.<br>
          <span class="text-primary">Find it later.</span>
        </h1>
        <p class="lead text-body-secondary">
          Save Button is an easy, private, searchable, local, and offline-friendly
          bookmark and breadcrumb service with apps for every platform we can think of.
        </p>
        <p class="text-body-secondary">
          Nerds may like that it is append-only, open source, local-first,
          file-based, and (optionally) self-host-able.
          <a href="#nerd-features">Read more.</a>
        </p>
        <div class="d-flex gap-2 mt-4">
          <%= link_to "Learn More", "#features", class: "btn btn-outline-secondary btn-lg" %>
          <%= link_to "Get The Apps", "#apps", class: "btn btn-primary btn-lg" %>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="row row-cols-2 g-3">
          <div class="col">
            <div class="card hero-card h-100 text-center p-3">
              <i class="bi bi-bookmark fs-1 text-primary mb-2"></i>
              <h6 class="card-title">Bookmarks</h6>
              <p class="card-text small text-body-secondary">Don't think, just bookmark it</p>
            </div>
          </div>
          <div class="col">
            <div class="card hero-card h-100 text-center p-3">
              <i class="bi bi-sticky fs-1 text-success mb-2"></i>
              <h6 class="card-title">Notes</h6>
              <p class="card-text small text-body-secondary">Passing thoughts and fieldstones</p>
            </div>
          </div>
          <div class="col">
            <div class="card hero-card h-100 text-center p-3">
              <i class="bi bi-file-earmark-text fs-1 text-info mb-2"></i>
              <h6 class="card-title">Documents</h6>
              <p class="card-text small text-body-secondary">PDFs, Office docs, and junk for work</p>
            </div>
          </div>
          <div class="col">
            <div class="card hero-card h-100 text-center p-3">
              <i class="bi bi-image fs-1 text-warning mb-2"></i>
              <h6 class="card-title">Images</h6>
              <p class="card-text small text-body-secondary">Screenshots, photos, and dank memes</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<section id="features" class="py-5">
  <div class="container">
    <h2 class="text-center fw-bold mb-5">Stupidly Simple</h2>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <div class="col">
        <div class="text-center">
          <div class="mb-3"><i class="bi bi-search fs-1 text-primary"></i></div>
          <h5>Find anything</h5>
          <p class="text-body-secondary">Search inside your notes, bookmarks, and documents from every app.</p>
        </div>
      </div>
      <div class="col">
        <div class="text-center">
          <div class="mb-3"><i class="bi bi-wifi-off fs-1 text-success"></i></div>
          <h5>Local & Offline</h5>
          <p class="text-body-secondary">Save Button is always available offline. Sync between devices.</p>
        </div>
      </div>
      <div class="col">
        <div class="text-center">
          <div class="mb-3"><i class="bi bi-eye-slash fs-1 text-secondary"></i></div>
          <h5>Private</h5>
          <p class="text-body-secondary">Your data belongs to you. <br>No ads, no social features.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="apps" class="py-5 bg-body-tertiary">
  <div class="container">
    <h2 class="text-center fw-bold mb-5">Get The Apps</h2>
    <%= render "shared/apps_content" %>
  </div>
</section>

<section id="nerd-features" class="py-5">
  <div class="container">
    <h2 class="text-center fw-bold mb-5">Hey, Nerds!</h2>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <div class="col">
        <div class="text-center">
          <div class="mb-3"><i class="bi bi-github fs-1 text-success"></i></div>
          <h5>Open Source</h5>
          <p class="text-body-secondary">
            AGPL-3.0 for your viewing pleasure.<br>
            <a href="https://github.com/lofimx">Get it here.</a> (Repos named "kaya-")
          </p>
        </div>
      </div>
      <div class="col">
        <div class="text-center">
          <div class="mb-3"><i class="bi bi-file-earmark-heart fs-1 text-secondary"></i></div>
          <h5>File-Based</h5>
          <p class="text-body-secondary">Bookmarks are ".url" files.<br>Metadata are ".toml" files.</p>
        </div>
      </div>
      <div class="col">
        <div class="text-center">
          <div class="mb-3"><i class="bi bi-hdd-rack fs-1 text-info"></i></div>
          <h5>Self-Host</h5>
          <p class="text-body-secondary">You know you want to even though it's always a terrible idea! <a href="https://github.com/lofimx/kaya-server">Here you go.</a></p>
        </div>
      </div>
      <div class="col">
        <div class="text-center">
          <div class="mb-3"><i class="bi bi-plus-square fs-1 text-danger"></i></div>
          <h5>Append-Only</h5>
          <p class="text-body-secondary">Immutable: there is no "delete."<br> Dumb data is good data.</p>
        </div>
      </div>
      <div class="col">
        <div class="text-center">
          <div class="mb-3"><i class="bi bi-arrow-repeat fs-1 text-warning"></i></div>
          <h5>Local-First</h5>
          <p class="text-body-secondary">Immutable files are easy to sync.<br>P2P sync coming soon.</p>
        </div>
      </div>
    </div>
  </div>
</section>
