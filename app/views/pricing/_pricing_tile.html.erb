<div class="<%= highlight ? "ring-2 ring-primary-400" : "border border-neutral-200 dark:border-neutral-800" %> bg-white dark:bg-neutral-900 rounded-2xl p-6 flex flex-col">
  <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100 mb-2"><%= name %></h2>
  <p class="text-3xl font-extrabold text-neutral-900 dark:text-neutral-100 mb-4"><%= price_label %></p>
  <ul class="text-sm text-neutral-600 dark:text-neutral-400 flex flex-col gap-2 mb-6 flex-1">
    <% features.each do |feature| %>
      <li class="flex items-start gap-2">
        <svg class="w-4 h-4 mt-0.5 text-primary-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        <span><%= feature %></span>
      </li>
    <% end %>
  </ul>

  <% if cta_method == :post %>
    <%= button_to cta_label, cta_path, method: :post, class: "w-full px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors cursor-pointer border-none" %>
  <% else %>
    <%= link_to cta_label, cta_path, class: "w-full inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 transition-colors no-underline" %>
  <% end %>
</div>
