<% active = current_page?(path) %>
<%= link_to path, class: "block px-2 py-1.5 text-sm rounded-md no-underline #{active ? "bg-primary-100 dark:bg-primary-500/20 text-neutral-900 dark:text-neutral-100 font-medium" : "text-neutral-600 dark:text-neutral-400 hover:bg-neutral-100 dark:hover:bg-neutral-800"}" do %>
  <%= label %>
<% end %>
