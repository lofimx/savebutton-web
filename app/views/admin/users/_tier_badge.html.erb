<% colors = {
  "free" => "bg-neutral-100 text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300",
  "basic" => "bg-blue-100 text-blue-700 dark:bg-blue-500/20 dark:text-blue-300",
  "advanced" => "bg-purple-100 text-purple-700 dark:bg-purple-500/20 dark:text-purple-300",
  "friend" => "bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-300"
} %>
<span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full <%= colors.fetch(subscription&.tier, colors["free"]) %>">
  <%= subscription&.tier&.capitalize || "Free" %>
</span>
