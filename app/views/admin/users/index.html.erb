<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100">Users</h1>
  <%= form_with url: admin_users_path, method: :get, local: true, class: "flex gap-2" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Search by email", class: "px-3 py-1.5 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 min-h-[36px] w-64" %>
    <%= f.submit "Search", class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-primary-400 hover:bg-primary-500 text-neutral-900 cursor-pointer border-none" %>
  <% end %>
</div>

<div class="bg-white dark:bg-neutral-900 rounded-2xl border border-neutral-200 dark:border-neutral-800 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-neutral-50 dark:bg-neutral-800/50 text-left text-xs uppercase tracking-wide text-neutral-500">
      <tr>
        <th class="px-4 py-3">Email</th>
        <th class="px-4 py-3">Role</th>
        <th class="px-4 py-3">Tier</th>
        <th class="px-4 py-3">Stripe</th>
        <th class="px-4 py-3 text-right">Bytes</th>
        <th class="px-4 py-3">Created</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr class="border-t border-neutral-200 dark:border-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-800/30">
          <td class="px-4 py-2"><%= link_to user.email_address, admin_user_path(user), class: "text-neutral-900 dark:text-neutral-100 underline" %></td>
          <td class="px-4 py-2 text-neutral-600 dark:text-neutral-400"><%= user.role %></td>
          <td class="px-4 py-2"><%= render "admin/users/tier_badge", subscription: user.subscription %></td>
          <td class="px-4 py-2 text-neutral-600 dark:text-neutral-400"><%= user.subscription&.stripe_status || "—" %></td>
          <td class="px-4 py-2 text-right text-neutral-600 dark:text-neutral-400"><%= number_to_human_size(user.subscription&.bytes_used.to_i) %></td>
          <td class="px-4 py-2 text-neutral-600 dark:text-neutral-400"><%= user.created_at.strftime("%Y-%m-%d") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
